[Unit]
Description=Suertech AI Developer Agent
After=network.target

[Service]
# Бот будет работать от имени этого пользователя
User=user1
Group=ai_agent

# Укажи путь, куда ты склонировал репозиторий
WorkingDirectory=/opt/my_second_brain

# Укажи путь к питону (рекомендуется использовать venv: /opt/my_second_brain/venv/bin/python)
ExecStart=/opt/my_second_brain/venv/bin/python3 -m src.bot.main

# Перезапуск при падении
Restart=always
RestartSec=10

# Перенаправление логов в syslog
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=suertech_agent

[Install]
WantedBy=multi-user.target
